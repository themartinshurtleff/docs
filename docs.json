{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "TradeNet",
  "colors": {
    "primary": "#c9a84c",
    "light": "#f0c040",
    "dark": "#c9a84c",
    "background": {
      "dark": "#09090f"
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "docs/introduction",
              "docs/installation",
              "docs/quickstart"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "docs/features/liquidation-heatmap",
              "docs/features/footprint-charts",
              "docs/features/orderbook-heatmap",
              "docs/features/open-interest",
              "docs/features/multi-exchange"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "docs/guides/reading-the-heatmap",
              "docs/guides/layouts-and-charts"
            ]
          }
        ]
      },
      {
        "tab": "Blog",
        "groups": [
          {
            "group": "Updates",
            "pages": [
              "blog/closed-beta-launch",
              "blog/why-we-built-tradenet"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Discord",
          "href": "https://discord.gg/tradenet",
          "icon": "discord"
        },
        {
          "anchor": "Website",
          "href": "https://tradenet.org",
          "icon": "globe"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/dark.svg",
    "dark": "/logo/light.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Discord",
        "href": "https://discord.gg/tradenet"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Join Waitlist",
      "href": "https://tradenet.org/terminal"
    }
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/tradenet",
      "x": "https://x.com/tradaborz"
    }
  }
}
